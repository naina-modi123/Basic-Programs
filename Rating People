public static int getStars(int rating) {
    // write your code here 
    int rate = 0;
    if(rating >= 0 && rating <= 399){
        rate += 1;
    }else if(rating >= 400 && rating <= 799){
        rate += 2;
    }else if(rating >= 800 && rating <= 1199){
        rate += 3;
    }else if(rating >= 1200 && rating <= 1599){
        rate += 4;
    }else if(rating >= 1600 && rating <= 2000){
        rate += 5;
    }
    return rate;
    
}
